APP_ENV=development
DEBUG=true
DATABASE_URL=postgresql+psycopg://postgres@127.0.0.1:5432/sutra
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVICE_ACCOUNT_JSON=your_firebase_service_account_json
MASTER_ENCRYPTION_KEY=your_master_encryption_key
SUTRA_FRONTEND_URL=http://localhost:5173

GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_PRIVATE_KEY=your_github_app_private_key

SUTRA_RUNTIME_PROVIDER=static_dev
SUTRA_DEV_RUNTIME_BASE_URL=http://127.0.0.1:8642
SUTRA_DEV_RUNTIME_API_KEY=your_runtime_api_key

GCS_BUCKET_NAME=your_runtime_bucket
GCP_SERVICE_ACCOUNT_JSON=gcs-service-account.json
GCP_PROJECT_ID=your_gcp_project
GCP_COMPUTE_ZONE=us-central1-a
GCP_RUNTIME_SOURCE_IMAGE=your_runtime_image
GCP_RUNTIME_SOURCE_IMAGE_FAMILY=
GCP_RUNTIME_SOURCE_IMAGE_PROJECT=your_runtime_image_project
GCP_RUNTIME_MACHINE_TYPE=e2-small
GCP_RUNTIME_BOOT_DISK_SIZE_GB=20
GCP_RUNTIME_STATE_DISK_SIZE_GB=50
GCP_RUNTIME_STATE_DISK_TYPE=pd-balanced
GCP_RUNTIME_STATE_MOUNT_PATH=/mnt/sutra/state
GCP_RUNTIME_HERMES_HOME_PATH=/mnt/sutra/state/hermes-home
GCP_RUNTIME_PRIVATE_VOLUME_PATH=/mnt/sutra/state/private-volume
GCP_RUNTIME_SHARED_WORKSPACE_PATH=/mnt/sutra/shared-workspace
GCP_RUNTIME_API_BIND_HOST=0.0.0.0
GCP_RUNTIME_HERMES_WORKDIR=/opt/hermes-agent
GCP_RUNTIME_PYTHON_VENV_PATH=/opt/sutra-runtime-venv
GCP_RUNTIME_GATEWAY_COMMAND=python -m gateway.run
GCP_RUNTIME_HERMES_BUNDLE_URI=gs://your_runtime_bucket/runtime-bundles/hermes-agent-dev.tar.gz
